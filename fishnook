<title>Fishnook × The Salt Lick Denver — Creative Production Proposal</title>
<link rel="stylesheet" href="https://use.typekit.net/csj2hfl.css">
<style>
  :root {
    --bg-gray: #e0dbd3;
    --bg-cream: #f0ebe2;
    --bg-card: #ffffff;
    --bg-dark: #1a1a1a;
    --accent-coral: #c85c4f;
    --accent-coral-dark: #9e4535;
    --accent-coral-tint: rgba(200, 92, 79, 0.08);
    --accent-green: #1a6b30;
    --accent-green-tint: rgba(26, 107, 48, 0.08);
    --star-gold: #e8a32e;
    --text-primary: #1a1a1a;
    --text-secondary: #3d3d3d;
    --text-muted: rgba(0, 0, 0, 0.45);
    --text-faint: rgba(0, 0, 0, 0.35);
    --text-inverse: #ffffff;
    --border-subtle: rgba(0, 0, 0, 0.08);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    background: var(--bg-gray);
    color: var(--text-primary);
    font-family: "neue-haas-grotesk-text", -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 16px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* NAVBAR */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: var(--bg-cream);
    border-bottom: 1px solid var(--border-subtle);
    z-index: 100;
    backdrop-filter: blur(8px);
  }
  .navbar-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .navbar-brand {
    font-family: "neue-haas-grotesk-display", sans-serif;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
  }
  .nav-menu {
    display: flex;
    gap: 28px;
    list-style: none;
  }
  .nav-menu a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-menu a:hover { color: var(--accent-coral); }
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 20px;
    color: var(--text-primary);
  }

  /* LAYOUT */
  .page {
    padding-top: 60px;
  }
  .panel {
    max-width: 860px;
    margin: 0 auto;
    background: var(--bg-cream);
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.06);
    padding: 80px 32px 60px;
  }
  .section { margin-bottom: 72px; }
  .section:last-child { margin-bottom: 0; }
  .section-divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 0 auto 72px;
    max-width: 100%;
  }

  /* TYPOGRAPHY */
  .section-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    margin-bottom: 12px;
  }
  h1, .heading_h1 {
    font-family: "neue-haas-grotesk-display", sans-serif;
    font-size: clamp(36px, 4vw, 44px);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }
  h2, .heading_h2 {
    font-family: "neue-haas-grotesk-display", sans-serif;
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin-bottom: 20px;
  }
  h3, .heading_h3 {
    font-family: "neue-haas-grotesk-display", sans-serif;
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 10px;
  }
  .body-text {
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 16px;
  }
  .body-text:last-child { margin-bottom: 0; }

  /* HERO */
  .hero-subtitle {
    color: var(--accent-coral);
    font-size: 18px;
    font-weight: 400;
    margin-bottom: 24px;
    line-height: 1.4;
  }
  .accent-bar {
    width: 48px;
    height: 3px;
    background: var(--accent-coral);
    margin-bottom: 28px;
  }

  /* TIER CARDS */
  .tiers-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }
  .tier-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 32px 28px;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .tier-card.featured {
    background: var(--bg-dark);
    color: var(--text-inverse);
    border: 1px solid var(--bg-dark);
  }
  .tier-card.featured .tier-name,
  .tier-card.featured .tier-price,
  .tier-card.featured .tier-description {
    color: var(--text-inverse);
  }
  .tier-card.featured .tier-cadence {
    color: rgba(255, 255, 255, 0.6);
  }
  .tier-card.featured .tier-summary-list li {
    color: rgba(255, 255, 255, 0.85);
    border-color: rgba(255, 255, 255, 0.12);
  }
  .tier-badge {
    position: absolute;
    top: -10px;
    right: 20px;
    background: var(--accent-coral);
    color: var(--text-inverse);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 5px 12px;
    border-radius: 4px;
  }
  .tier-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 10px;
    border-radius: 4px;
    margin-bottom: 14px;
  }
  .tier-tag.starter {
    background: var(--accent-green-tint);
    color: var(--accent-green);
  }
  .tier-tag.growth {
    background: rgba(200, 92, 79, 0.2);
    color: var(--accent-coral);
  }
  .tier-name {
    font-family: "neue-haas-grotesk-display", sans-serif;
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .tier-description {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 20px;
    line-height: 1.5;
  }
  .tier-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 24px;
  }
  .tier-price {
    font-family: "neue-haas-grotesk-display", sans-serif;
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .tier-cadence {
    font-size: 14px;
    color: var(--text-muted);
  }
  .tier-summary-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tier-summary-list li {
    padding: 10px 0;
    font-size: 14px;
    color: var(--text-secondary);
    border-top: 1px solid var(--border-subtle);
    line-height: 1.5;
  }
  .tier-summary-list li:first-child {
    border-top: none;
    padding-top: 0;
  }
  .tier-summary-list li:last-child {
    padding-bottom: 0;
  }

  /* INVESTMENT FOOTNOTES */
  .investment-footnotes {
    margin-top: 12px;
    padding: 20px 24px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
  }
  .investment-footnotes p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.55;
    margin-bottom: 8px;
  }
  .investment-footnotes p:last-child { margin-bottom: 0; }
  .investment-footnotes strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* WHAT'S INCLUDED CARDS */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .deliverable-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 24px;
  }
  .deliverable-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 10px;
    border-radius: 4px;
    background: var(--accent-coral-tint);
    color: var(--accent-coral-dark);
    margin-bottom: 12px;
  }
  .deliverable-tag.core {
    background: var(--accent-green-tint);
    color: var(--accent-green);
  }

  /* DELIVERABLES ACCORDION */
  .deliverables-intro {
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 20px;
  }
  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg-card);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
  }
  .pricing-table thead th {
    background: rgba(0, 0, 0, 0.02);
    padding: 14px 20px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-align: left;
    border-bottom: 1px solid var(--border-subtle);
  }
  .pricing-row {
    cursor: pointer;
    transition: background 0.15s ease;
    border-bottom: 1px solid var(--border-subtle);
  }
  .pricing-row:hover { background: rgba(200, 92, 79, 0.04); }
  .pricing-row td {
    padding: 18px 20px;
    vertical-align: top;
  }
  .pricing-row td:first-child {
    width: 42%;
    font-weight: 600;
    position: relative;
    padding-right: 32px;
  }
  .pricing-row td:last-child {
    color: var(--text-secondary);
    font-size: 14px;
  }
  .expand-icon {
    position: absolute;
    right: 20px;
    top: 18px;
    font-size: 20px;
    font-weight: 400;
    color: var(--accent-coral);
    transition: transform 0.2s ease;
  }
  .pricing-details {
    display: none;
    background: rgba(0, 0, 0, 0.02);
  }
  .pricing-details.active { display: table-row; }
  .pricing-details td {
    padding: 18px 24px 24px;
    border-top: 1px dashed var(--border-subtle);
  }
  .pricing-details ul {
    list-style: none;
    padding: 0;
  }
  .pricing-details li {
    padding: 6px 0 6px 24px;
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.55;
    position: relative;
  }
  .pricing-details li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent-coral);
    font-weight: 500;
  }
  .tier-label {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 7px;
    border-radius: 3px;
    margin-left: 8px;
    vertical-align: middle;
  }
  .tier-label.starter {
    background: var(--accent-green-tint);
    color: var(--accent-green);
  }
  .tier-label.growth {
    background: var(--accent-coral-tint);
    color: var(--accent-coral-dark);
  }

  /* TIMELINE */
  .timeline-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-top: 24px;
  }
  .timeline-step {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    padding: 20px 18px;
  }
  .timeline-step-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-coral);
    margin-bottom: 8px;
  }
  .timeline-step-title {
    font-family: "neue-haas-grotesk-display", sans-serif;
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 6px;
  }
  .timeline-step-detail {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.45;
  }
  .timeline-caption {
    margin-top: 20px;
    padding: 16px 20px;
    background: rgba(200, 92, 79, 0.06);
    border-left: 3px solid var(--accent-coral);
    border-radius: 0 8px 8px 0;
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  /* WHY SALT LICK */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 24px;
  }
  .why-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 28px 24px;
  }
  .why-card h3 {
    font-size: 18px;
    margin-bottom: 10px;
  }
  .why-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  /* CREDENTIALS */
  .reviews-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 24px;
  }
  .stars {
    color: var(--star-gold);
    letter-spacing: 2px;
    font-size: 16px;
  }
  .review-count {
    font-weight: 600;
    font-size: 14px;
  }
  .review-source {
    font-size: 13px;
    color: var(--text-muted);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .trust-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 24px;
  }
  .trust-card h3 {
    font-size: 16px;
    margin-bottom: 8px;
  }
  .trust-card p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  /* CTA */
  .cta-section {
    background: var(--bg-dark);
    color: var(--text-inverse);
    border-radius: 16px;
    padding: 48px 40px;
    text-align: center;
  }
  .cta-section h2 {
    color: var(--text-inverse);
    margin-bottom: 16px;
  }
  .cta-section p {
    color: rgba(255, 255, 255, 0.7);
    max-width: 480px;
    margin: 0 auto 28px;
    font-size: 15px;
  }
  .cta-button {
    display: inline-block;
    background: var(--accent-coral);
    color: var(--text-inverse);
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .cta-button:hover {
    background: #b04a3f;
    transform: translateY(-1px);
  }
  .calendar-embed {
    background: var(--bg-card);
    border-radius: 12px;
    margin-top: 32px;
    padding: 20px;
    min-height: 600px;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .navbar-inner { padding: 14px 20px; }
    .nav-toggle { display: block; }
    .nav-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg-cream);
      flex-direction: column;
      padding: 16px 20px;
      gap: 14px;
      border-bottom: 1px solid var(--border-subtle);
    }
    .nav-menu.active { display: flex; }
    .panel { padding: 60px 20px 40px; }
    .section { margin-bottom: 56px; }
    .section-divider { margin-bottom: 56px; }
    .tiers-grid,
    .services-grid,
    .why-grid,
    .trust-grid {
      grid-template-columns: 1fr;
    }
    .timeline-grid {
      grid-template-columns: 1fr 1fr;
    }
    .pricing-row td:first-child { width: 50%; padding-right: 28px; }
    .cta-section { padding: 36px 24px; }
  }
  @media (max-width: 480px) {
    .timeline-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
